{
  "name": "easyproj",
  "version": "1.0.0",
  "description": "Easy project management",
  "license": "ISC",
  "author": "Cauê Santos",
  "main": "index.js",
  "scripts": {
    "dev": "npm run services:up && npm run wait-for-postgres && next dev",
    "services:up": "docker compose -f infra/compose.yaml up -d",
    "services:down": "docker compose -f infra/compose.yaml down",
    "services:stop": "docker compose -f infra/compose.yaml stop",
    "migrations:create": "node-pg-migrate -m ./infra/migrations create",
    "migrations:up": "node-pg-migrate -m ./infra/migrations up --env-path ./.env.development",
    "migrations:down": "node-pg-migrate -m ./infra/migrations down --env-path ./.env.development",
    "test": "concurrently -c red,blue -n next,jest --hide next --success command-jest --kill-others \"npm run dev\" \"jest --runInBand --verbose\"",
    "test:watch": "jest --watch --runInBand",
    "lint:prettier:check": "prettier --check .",
    "lint:prettier:fix": "prettier --write .",
    "lint:eslint:check": "npx eslint .",
    "wait-for-postgres": "node infra/scripts/wait-for-postgres.js"
  },
  "dependencies": {
    "async-retry": "1.3.3",
    "dotenv": "17.4.2",
    "dotenv-expand": "13.0.0",
    "next": "16.2.6",
    "pg": "8.21.0",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.2",
    "concurrently": "9.2.1",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jest": "28.14.0",
    "jest": "30.4.2",
    "jest-environment-jsdom": "30.4.1",
    "node-pg-migrate": "7.9.1",
    "prettier": "3.8.3"
  }
}
